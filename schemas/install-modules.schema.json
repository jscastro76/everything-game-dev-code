{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/install-modules.schema.json",
  "title": "Install Modules Map",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "description",
    "modules"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "modules": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "includes",
          "notes"
        ],
        "properties": {
          "includes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^(\\\\*\\\\*|[A-Za-z0-9._@/\\\\-*]+)$"
            },
            "uniqueItems": true
          },
          "excludes": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^(\\\\*\\\\*|[A-Za-z0-9._@/\\\\-*]+)$"
            },
            "uniqueItems": true
          },
          "notes": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
