{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/install-components.schema.json",
  "title": "Install Components Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "description",
    "components"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "family",
          "summary",
          "modules"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^(baseline|engine|domain|capability):[a-z0-9][a-z0-9-]*$"
          },
          "family": {
            "type": "string",
            "enum": [
              "baseline",
              "engine",
              "domain",
              "capability"
            ]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "modules": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9-]*$"
            },
            "uniqueItems": true
          }
        }
      }
    }
  }
}
