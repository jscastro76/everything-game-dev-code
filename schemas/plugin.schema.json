{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/plugin.schema.json",
  "title": "Plugin Metadata",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "name",
    "version"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "license": {
      "type": "string"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "source": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "source": {
          "type": "string"
        },
        "repo": {
          "type": "string"
        }
      }
    }
  }
}
