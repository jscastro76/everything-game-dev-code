{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/role-matrix.schema.json",
  "title": "Role Matrix",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "roles"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "summary"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "skills": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "commands": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "handoffs_to": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "engine_scope": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "common",
                "unity",
                "unreal",
                "godot"
              ]
            },
            "uniqueItems": true
          }
        }
      }
    }
  }
}
