{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/install-state.schema.json",
  "title": "Install State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "active_profile": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "installed_components": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(baseline|engine|domain|capability):[a-z0-9][a-z0-9-]*$"
      },
      "uniqueItems": true
    },
    "installed_modules": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      },
      "uniqueItems": true
    },
    "active_engine": {
      "type": "string",
      "enum": [
        "unity",
        "unreal",
        "godot"
      ]
    },
    "installed_at": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
